# DailyGate Data API — environment variables
# Copy to .env and fill in your values. Never commit .env.

# Langfuse (optional — leave blank to run without observability)
# Get keys at https://cloud.langfuse.com or your self-hosted instance
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
